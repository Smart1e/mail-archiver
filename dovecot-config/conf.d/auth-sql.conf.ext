passdb {
  driver = sql
  args = /etc/dovecot/dovecot-sql.conf.ext
}

# Static userdb — the home dir is derived from the account Id returned by the passdb query
# (see dovecot-sql.conf.ext). Dovecot refuses uid=0 for IMAP workers, so use a normal
# numeric mail uid. The app makes Maildir paths group/world writable inside the private
# Docker volume so Dovecot can create indexes and update mailbox metadata.
userdb {
  driver = static
  args = uid=5000 gid=5000 home=/var/mail/%u
}
